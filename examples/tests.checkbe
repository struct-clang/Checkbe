import Bridge

body Application {
    func main(argc: int, argv: string[]) {
        Bridge.println("\(argc) args, args: \(argv)")
        if (argc > 1) {
            Bridge.println("argv[1] = \(argv[1])")
        } else {
            Bridge.println("argv[1] is missing")
        }

        Bridge.sleep(0)
        Bridge.usleep(0)
        Bridge.system("echo", "main argc/argv support works")
    }
}
